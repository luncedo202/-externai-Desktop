rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User data - users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Integration credentials - users can read/write their own credentials
    match /integrationCredentials/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Published apps metadata - publicly readable, write via Cloud Functions
    match /publishedApps/{appId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions can write
    }

    // Conversation history - users can read/write their own conversations
    match /conversations/{userId}/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
